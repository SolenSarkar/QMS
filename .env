# Local Development Environment Variables
# Copy this file to .env.local for local development

# API Configuration
# Options: 'local' for localhost:5000, 'production' or 'render' for qms-sjuv.onrender.com
VITE_PREFERRED_API=local

# Alternative: Directly set the API URL (takes precedence if set)
# VITE_API_URL=http://localhost:5000
# VITE_API_URL=https://qms-sjuv.onrender.com

# App Mode (development, production, test)
VITE_APP_MODE=development

# Enable logging
VITE_ENABLE_LOGGING=true

