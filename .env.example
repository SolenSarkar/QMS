# Environment Variables for QMS Application
# Copy this file to .env and fill in the values

# ===================
# Required for Production
# ===================

# API URL - REQUIRED for production deployment
# This is your backend API URL hosted on Render, Railway, or another service
# Example: https://your-backend-app.onrender.com
VITE_API_URL=http://localhost:5000

# ===================
# Optional Variables
# ===================

# Deployment URL (optional - for analytics/tracking)
# VITE_DEPLOYMENT_URL=https://your-app.vercel.app

# App Mode (development, production)
# VITE_APP_MODE=production

# Enable Logging (true/false)
# VITE_ENABLE_LOGGING=false

# ===================
# Firebase Config (if using Firebase features)
# ===================
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# ===================
# MongoDB (for local development only)
# ===================
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/qms

